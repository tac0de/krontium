---
import { languages, type Language } from "../data/i18n";

const entries = Object.entries(languages) as [Language, (typeof languages)[Language]][];
const base = import.meta.env.BASE_URL;
---

<nav class="language-grid" aria-label="Language records">
  {entries.map(([code, language]) => (
    <a href={`${base}${code}/`} class="language-tile">
      <span>{language.short}</span>
      <strong>{language.label}</strong>
    </a>
  ))}
</nav>
