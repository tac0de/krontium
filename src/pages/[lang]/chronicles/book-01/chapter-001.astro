---
import { languageCodes, languages, type Language } from "../../../../data/i18n";
import KrontiumField from "../../../../components/KrontiumField.astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return languageCodes.map((lang: Language) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Language;
const copy = languages[lang];
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`${copy.readerLabel} - Krontium`} description={copy.subtitle}>
  <main class="fragment-page">
    <nav class="reader-nav" aria-label="Reader navigation">
      <a href={`${base}${lang}/`} class="silent-link" aria-label="Return to language artwork"></a>
      <a href={base} class="silent-link" aria-label="Return to Krontium artwork"></a>
    </nav>

    <KrontiumField />
  </main>
</BaseLayout>
