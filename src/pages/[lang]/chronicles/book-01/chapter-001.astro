---
import { chapterSample, marginalia } from "../../../../data/krontium";
import { languageCodes, languages, type Language } from "../../../../data/i18n";
import BaseLayout from "../../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return languageCodes.map((lang: Language) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Language;
const copy = languages[lang];
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`${copy.readerLabel} - Krontium`} description={copy.subtitle}>
  <main class="reader-page">
    <nav class="reader-nav" aria-label="Reader navigation">
      <a href={`${base}${lang}/`}>{copy.archive}</a>
      <a href={base}>{copy.languagePrompt}</a>
    </nav>

    <article class="chapter">
      <header class="chapter-head">
        <p class="kicker">{copy.readerLabel}</p>
        <h1>The Bark Measurement</h1>
        <dl>
          <div>
            <dt>Source</dt>
            <dd>Neutral Cloister, third winter ledger</dd>
          </div>
          <div>
            <dt>Witness</dt>
            <dd>battlefield specimen, unblessed</dd>
          </div>
          <div>
            <dt>Status</dt>
            <dd>translation draft, doctrine disputed</dd>
          </div>
        </dl>
      </header>

      <div class="translation-layout">
        <div class="prose">
          {chapterSample.map((paragraph: string) => <p>{paragraph}</p>)}
        </div>
        <aside class="marginalia" aria-label="Marginal notes">
          {marginalia.map((note: string, index: number) => (
            <p><span>{String(index + 1).padStart(2, "0")}</span>{note}</p>
          ))}
        </aside>
      </div>
    </article>
  </main>
</BaseLayout>
