---
import BaseLayout from "../layouts/BaseLayout.astro";
import LanguageGrid from "../components/LanguageGrid.astro";
---

<BaseLayout
  title="Krontium"
  description="An experimental multilingual CSS art field."
>
  <main class="shell">
    <section class="art-field" aria-labelledby="site-title">
      <div class="css-sculpture" aria-hidden="true">
        <div class="orbit orbit-a"></div>
        <div class="orbit orbit-b"></div>
        <div class="orbit orbit-c"></div>
        <div class="root-array"></div>
        <div class="wing-array"></div>
        <div class="ink-array"></div>
        <div class="pressure-lines"></div>
      </div>
      <div class="art-copy">
        <p class="mono">CSS ART FIELD / NO SYNOPSIS / LIVE BROWSER SURFACE</p>
        <h1 id="site-title">Krontium</h1>
        <p>
          A multilingual field of root, wing, ink, pressure, and unstable type.
          The novel stays elsewhere. This page is the signal.
        </p>
        <LanguageGrid />
      </div>
      <aside class="field-readout" aria-label="CSS readout">
        <span>render mode</span>
        gradients / masks / borders / transforms / no canvas / no image hero
      </aside>
    </section>
  </main>
</BaseLayout>
