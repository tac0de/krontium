---
import BaseLayout from "../layouts/BaseLayout.astro";
import LanguageGrid from "../components/LanguageGrid.astro";
---

<BaseLayout
  title="Krontium Archive"
  description="A multilingual archive for the grounded epic fantasy novel Krontium."
>
  <main class="shell">
    <section class="index-slab" aria-labelledby="site-title">
      <div class="slab-visual" aria-hidden="true">
        <img class="slab-plate slab-plate--earth" src={`${import.meta.env.BASE_URL}plates/earth.svg`} alt="" />
        <img class="slab-plate slab-plate--sky" src={`${import.meta.env.BASE_URL}plates/sky.svg`} alt="" />
        <img class="slab-plate slab-plate--sea" src={`${import.meta.env.BASE_URL}plates/sea.svg`} alt="" />
        <div class="slab-map">
          <img src={`${import.meta.env.BASE_URL}plates/war-atlas.svg`} alt="" />
        </div>
      </div>
      <div class="slab-copy">
        <p class="kicker">Neutral Cloister / Index Slab / Restricted Translation</p>
        <h1 id="site-title">Krontium</h1>
        <p>
          Three ancient gods leave bodies in history. Monks measure what priests
          forbid, armies exploit what temples deny, and humans survive by making
          memory faster than flesh.
        </p>
        <LanguageGrid />
      </div>
      <aside class="slab-note" aria-label="Archive provenance">
        <span>provenance</span>
        Preserved from battlefield specimens, treaty copies, port ledgers, and
        marginal objections copied under neutral seal.
      </aside>
    </section>
  </main>
</BaseLayout>
